DATABASE_URL=postgresql://user:password@localhost:5432/elegance_studio
NODE_ENV=development

# Email Configuration (Optional - Contact form works without these, but email notifications won't be sent)
# Choose ONE email method below:

# Option 1: Gmail
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Option 2: SMTP Server
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-password
# SMTP_FROM_EMAIL=noreply@example.com

# Email Receiver
CONTACT_RECEIVER_EMAIL=receiver@example.com

# CORS Configuration (for Render or other deployments)
# Set to your frontend URL when deploying to production
# On Render, if frontend and backend are in the same service: CORS_ORIGIN=https://your-app.onrender.com
# For development, defaults to localhost:5000 and localhost:5173
# CORS_ORIGIN=https://your-app.onrender.com

# --- RENDER DEPLOYMENT GUIDE ---
# 1. Create a PostgreSQL database on Render
# 2. Add DATABASE_URL from your Render database
# 3. Set up Gmail App Password and add credentials
# 4. After deploying, update CORS_ORIGIN with your Render service URL
# 5. Redeploy after environment variable changes

