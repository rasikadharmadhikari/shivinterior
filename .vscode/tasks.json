{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run project (dev)",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev"
			],
			"isBackground": true
		},
		{
			"label": "Run project (dev windows)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"$env:NODE_ENV='development'; npx tsx server/index.ts"
			],
			"isBackground": true
		},
		{
			"label": "Run project (dev cmd)",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"set NODE_ENV=development&& npx tsx server/index.ts"
			],
			"isBackground": true
		},
		{
			"label": "Run project (dev cmd)",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"set NODE_ENV=development&& npx tsx server/index.ts"
			],
			"isBackground": true
		},
		{
			"label": "Run project (dev node-import)",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"set NODE_ENV=development&& node --import tsx server/index.ts"
			],
			"isBackground": true
		}
	]
}